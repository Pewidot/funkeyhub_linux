# The U.B. Funkeys / FunkeyOne installer and any extracted game data
UBFunkeys-Setup-x64.exe
*Setup*.exe
# Adobe Flash Player control and any Flash content (Adobe copyright)
*.ocx
*.swf
*.tlb
# Game data / save / log files that may embed game content
*.rdf
MegaByte_log.txt
# App icon — fetched from funkeyone.com's favicon at install time, not shipped
*.ico
# Installer/payload bundles that carry game + Adobe binaries (never redistribute).
# The revival client is EXTRACTED from the user's own installer at install time.
Funkeyone-installer-linux.zip
ClientPayload.zip
*Full*Game*.zip
*Full_Game*.zip

# ============================================================================
# Build artifacts — rebuilt from source by setup.sh / the build.sh scripts.
# (NOTE: .gitignore has no inline comments — keep patterns on their own lines.)
# ============================================================================
# our compiled shims: flashshim.dll, ninput.dll
*.dll
# winelib bridge: libusb-1.0.dll.so
*.dll.so
# winelib test helpers: decoy.exe.so etc.
*.exe.so
# any Windows exe (installer covered above; also decoy.exe build helper)
*.exe
*.o
*.a
*.obj
# winebridge / wineflash scratch outputs
winebridge/portalcheck
winebridge/decoy
packaging/winebridge/funkeyusbd
packaging/winebridge/portalcheck
wineflash/original_inprocserver32.txt

# ============================================================================
# Scratch / editor / OS
# ============================================================================
*.log
*.swp
*~
.DS_Store
/scratch/

# large / build outputs (never commit)
*.iso
*.deb

# VM / test artifacts
*.qcow2
*.img
*.vmdk
funkeyone-vm/
# game-install backups the setup makes in place
*.orig-backup
